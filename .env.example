SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///instance/bloodlink.db
PORT=8000

# SMTP settings for OTP and password reset emails
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
