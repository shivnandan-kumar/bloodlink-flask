SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///instance/bloodlink.db
PORT=8000

# SMTP settings for OTP and password reset emails
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-app-password
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=BloodLink <your-email@example.com>

# Optional default admin account for local recovery
DEFAULT_ADMIN_NAME=BloodLink Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeThisAdminPassword1!
DEFAULT_ADMIN_CITY=Ranchi
DEFAULT_ADMIN_PINCODE=834001
DEFAULT_ADMIN_BLOOD_GROUP=O+
